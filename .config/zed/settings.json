// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // === UI/Editor Config ====================================================
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "agent_ui_font_size": 16.0,
  "agent_buffer_font_size": 15.0,
  "base_keymap": "SublimeText",
  "buffer_font_family": "PragmataPro Mono Liga",
  "buffer_font_features": {
    "dlig": true,
    "ss13": true,
    "ss15": true,
    "ss18": true,
  },
  "buffer_font_size": 16.0,
  "buffer_line_height": "comfortable",
  "cursor_blink": false,
  "icon_theme": {
    "dark": "Zed (Default)",
    "light": "Zed (Default)",
    "mode": "system",
  },
  "show_wrap_guides": true,
  "tabs": {
    "close_position": "left",
  },
  "theme": {
    "dark": "Duskfox - opaque",
    "light": "Dayfox - opaque",
    "mode": "system",
  },
  "theme_overrides": {
    "Sublime Breakers": {
      "editor.wrap_guide": "#e0e0e0",
    },
  },
  "ui_font_family": ".ZedSans",
  "ui_font_size": 16,
  "vim_mode": true,
  "wrap_guides": [79, 88, 100, 120],

  // === Languages ===========================================================
  "languages": {
    "Markdown": {
      "soft_wrap": "bounded",
      "preferred_line_length": 79,
    },
  },

  // === Features / AI =======================================================
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "tool_permissions": {
      "default": "allow"
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-opus-4.5",
    },
    "use_modifier_to_send": true,
    "default_model": {
      "model": "gpt-5.2",
      "provider": "copilot_chat",
    },
    "default_profile": "write",
    "model_parameters": [],
  },
  "collaboration_panel": {
    "dock": "left",
    "button": true,
  },
  "preview_tabs": {
    "enable_preview_multibuffer_from_code_navigation": true,
    "enable_keep_preview_on_code_navigation": true,
  },
  "use_system_path_prompts": false,
  // === Extensions ==========================================================
  "auto_install_extensions": {
    "basher": true,
    "crates-lsp": true,
    "editorconfig": true,
    "fish": true,
    "git-firefly": true,
    "html": true,
    "java": true,
    "jinja2": true,
    "nvim-nightfox": true,
    "oxc": true,
    "oxlint": true,
    "proto": true,
    "starlark": true,
    "sublime-mariana-theme": true,
    "toml": true,
    "xml": true,
  },

  // === CUSTOM ==============================================================
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "cursor-agent": {
      "type": "custom",
      "command": "pnpx",
      "args": ["@blowmage/cursor-agent-acp"],
      "env": {},
    },
  },
}
